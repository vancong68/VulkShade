{
  "schemaVersion": 1,
  "id": "vulkanmod",
  "version": "${version}",

  "name": "VulkShade",
  "description": "Shader-enabled fork of VulkanMod for Minecraft.",
  "authors": [
    "ericpandev"
  ],
  "contributors": [
    "Collateral (original VulkanMod author)"
  ],
  "contact": {
    "homepage": "",
    "sources": "https://github.com/xCollateral/VulkanMod"
  },

  "icon": "assets/vulkanmod/vlogo.png",

  "environment": "client",
  "entrypoints": {
    "client": [
      "net.vulkanmod.Initializer"
    ]
  },
  "mixins": [
    "vulkanmod.mixins.json"
  ],
  "accessWidener" : "vulkanmod.accesswidener",

  "depends": {
    "fabricloader": ">=0.14.14",
    "minecraft": ["1.21.9", "1.21.10"]
  },
  "custom": {
    "fabric-renderer-api-v1:contains_renderer": true
  }
}
